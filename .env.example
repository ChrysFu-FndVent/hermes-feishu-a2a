HERMES_ENV=development
HERMES_HOST=0.0.0.0
HERMES_PORT=8080
HERMES_DATABASE_URL=sqlite:///./data/hermes.db
HERMES_LOG_LEVEL=INFO
HERMES_SECRET_KEY=replace-with-32-or-more-random-bytes
HERMES_INTERNAL_API_TOKEN=replace-with-a-long-random-token

# Feishu developer console values. Never commit real values.
HERMES_FEISHU_DOMAIN=https://open.feishu.cn
HERMES_FEISHU_APP_ID=cli_xxx
HERMES_FEISHU_APP_SECRET=replace-me
HERMES_FEISHU_ENCRYPT_KEY=replace-me
HERMES_FEISHU_VERIFICATION_TOKEN=replace-me
HERMES_FEISHU_WEBHOOK_SIGNATURE_REQUIRED=true
HERMES_FEISHU_ALLOWED_CHAT_IDS=oc_xxx
HERMES_FEISHU_OWNER_OPEN_IDS=ou_xxx
HERMES_FEISHU_TOKEN_CACHE_PATH=./data/feishu-token.json

# Optional: encrypt locally persisted secrets with Fernet.
HERMES_SECRET_ENCRYPTION_KEY=
