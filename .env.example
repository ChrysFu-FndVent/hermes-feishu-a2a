HERMES_ENV=production
HERMES_HOST=127.0.0.1
HERMES_PORT=8080
# Host port used by Docker Compose; the container always listens on 8080.
HERMES_PUBLISHED_PORT=8080
HERMES_DATABASE_URL=sqlite:///./data/hermes.db
HERMES_LOG_LEVEL=INFO
HERMES_INTERNAL_API_TOKEN=replace-with-a-long-random-token
HERMES_AGENTS_CONFIG_PATH=config/agents.yaml
HERMES_MAX_CONCURRENCY=8
HERMES_DEFAULT_TASK_TIMEOUT_SECONDS=120

# Feishu developer console values. Never commit real values.
HERMES_FEISHU_DOMAIN=https://open.feishu.cn
HERMES_FEISHU_APP_ID=cli_xxx
HERMES_FEISHU_APP_SECRET=replace-me
HERMES_FEISHU_ENCRYPT_KEY=replace-me
HERMES_FEISHU_VERIFICATION_TOKEN=replace-me
HERMES_FEISHU_WEBHOOK_SIGNATURE_REQUIRED=true
HERMES_FEISHU_ALLOWED_CHAT_IDS=oc_xxx
HERMES_FEISHU_OWNER_OPEN_IDS=ou_xxx
# Authorized human file messages are routed to this registered Agent.
HERMES_FEISHU_FILE_INTAKE_AGENT_ID=researcher
HERMES_FEISHU_FILE_MAX_COUNT=8
HERMES_FEISHU_FILE_MAX_BYTES=20971520
HERMES_FEISHU_FILE_MAX_UNCOMPRESSED_BYTES=104857600
HERMES_FEISHU_FILE_MAX_EXTRACTED_CHARS=60000
HERMES_FEISHU_FILE_MAX_TOTAL_CHARS=120000
HERMES_FEISHU_FILE_MAX_AGENT_CHARS=30000
HERMES_FEISHU_FILE_RESULT_REPLY_CHARS=24000
HERMES_FEISHU_FILE_ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.md,.csv,.json
