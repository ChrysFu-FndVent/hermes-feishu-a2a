# Hermes coordinator
NODE_ENV=development
HOST=127.0.0.1
PORT=8787
LOG_LEVEL=info

# Feishu/Lark Open Platform. Never commit real values.
FEISHU_DOMAIN=feishu
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=replace-me
FEISHU_ENCRYPT_KEY=replace-me
FEISHU_VERIFICATION_TOKEN=replace-me
FEISHU_DEFAULT_CHAT_ID=oc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HMAC used for trusted agent envelopes. Use: openssl rand -hex 32
A2A_SIGNING_SECRET=replace-with-a-random-32-byte-secret
A2A_TASK_TTL_SECONDS=900
A2A_MAX_RETRIES=2
A2A_HEALTH_INTERVAL_SECONDS=60

# Optional comma-separated allow-list for inbound human open_ids.
A2A_ALLOWED_HUMAN_OPEN_IDS=
